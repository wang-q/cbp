{
  "name": "pgr",
  "version": "0.2.0",
  "description": "Population Genomes Refiner",
  "homepage": "https://github.com/wang-q/pgr",
  "license": "MIT",
  "type": "prebuild",
  "downloads": {
    "linux": {
      "url": "https://github.com/wang-q/pgr/releases/download/v0.2.0/pgr-x86_64-unknown-linux-gnu.tar.gz",
      "extract": "tar xvfz",
      "binary": "pgr"
    },
    "macos": {
      "url": "https://github.com/wang-q/pgr/releases/download/v0.2.0/pgr-x86_64-apple-darwin.tar.gz",
      "extract": "tar xvfz",
      "binary": "pgr"
    },
    "windows": {
      "url": "https://github.com/wang-q/pgr/releases/download/v0.2.0/pgr-x86_64-pc-windows-msvc.zip",
      "extract": "unzip",
      "binary": "pgr.exe"
    }
  },
  "tests": [
    {
      "name": "version",
      "command": "pgr",
      "pattern": "pgr [0-9]+\\.",
      "args": "--version"
    }
  ]
}
